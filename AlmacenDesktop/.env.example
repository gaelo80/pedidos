# Configuración de AlmacenDesktop

# URL base del API Django
# Para desarrollo: http://127.0.0.1:8000/api
# Para producción: https://tudominio.com/api
ALMACEN_API_URL=http://127.0.0.1:8000/api

# (Opcional) Token de fallback si no se puede autenticar
# ALMACEN_FALLBACK_TOKEN=tu_token_aqui

# (Opcional) Intervalo de sincronización en segundos (default: 60)
# ALMACEN_SYNC_INTERVAL=60
